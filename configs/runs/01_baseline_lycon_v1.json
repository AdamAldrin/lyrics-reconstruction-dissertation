{
  "experiment_name": "baseline-lycon-v1",
  "dataset": {
    "input_root": "data/raw/music4all",
    "output_file": "data/samples/music4all_sample_with_prompt_inputs.csv",
    "max_rows": 10,
    "candidate_multiplier": 20,
    "top_k_vocab": 50,
    "english_only": true,
    "random_seed": 42,
    "deduplicate_lines": true,
    "min_token_length": 3,
    "primary_vocab_strategy": "content"
  },
  "prompt_dataset": {
    "output_file": "data/processed/prompt_dataset.csv"
  },
  "prompt_variants": [
    {
      "name": "baseline_lycon",
      "template_file": "prompts/reproduction_v1.txt",
      "vocab_words_column": "vocab_words",
      "vocab_freq_column": "",
      "requires_structure": false
    }
  ],
  "generation": {
    "model_name": "gpt-4o-mini",
    "max_rows": 1,
    "sleep_between_calls": 1.0,
    "max_retries": 3,
    "dry_run": false
  },
  "evaluation": {
    "top_keyword_k": 10
  }
}
